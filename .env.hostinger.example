# Configuração do Armazenamento da Hostinger
# Copie este arquivo para .env.local e preencha com os valores reais

# URLs base dos buckets da Hostinger
VITE_HOSTINGER_PUBLIC_URL=https://cdn.seu-dominio.com/storage/public
VITE_HOSTINGER_PRIVATE_URL=https://api.seu-dominio.com/storage/private

# Endpoint da API de proxy para URLs assinadas
VITE_HOSTINGER_SIGNED_URL_API=https://api.seu-dominio.com/api/signed-url

# Chave de API para autenticação com o serviço de proxy (se necessário)
VITE_HOSTINGER_API_KEY=sua-chave-api-aqui

# Duração padrão das URLs assinadas (em segundos)
VITE_HOSTINGER_SIGNED_URL_EXPIRATION=3600
